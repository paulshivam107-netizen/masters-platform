# Pilot environment template
# Copy to a secure, non-committed location and fill real values.

APP_ENV=pilot
MOCK_MODE=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Required: 32+ random chars. Example command:
# openssl rand -hex 32
SECRET_KEY=replace-with-64-hex-chars-or-long-random-string

# Default token windows are fine for pilot unless you want tighter sessions.
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Pilot DB (SQLite default, or set a managed DB URL)
DATABASE_URL=sqlite:///./mba_platform.db

# Required in pilot mode
ADMIN_EMAILS=you@yourdomain.com

# Required in pilot mode for real email verification/password reset/reminders
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@yourdomain.com

# Frontend domain(s) allowed to call backend
CORS_ORIGINS=https://app.yourdomain.com
# Optional regex for preview/frontends (example for Cloudflare Pages previews):
# CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\\.)?your-pages-project\\.pages\\.dev$

# Keep empty/false in pilot
EXPOSE_DEV_AUTH_TOKENS=

# Optional
GOOGLE_CLIENT_ID=
